<%- include('header', { title: 'Pacientes', page: 'pacientes' }) %>

<div class="card">
  <h2>Pacientes</h2>

  <div class="toolbar">
    <form class="search-form" method="GET" action="/pacientes">
      <input type="text" name="buscar" placeholder="Buscar por nombre, teléfono o email..." value="<%= buscar %>" style="min-width: 300px;">
      <button type="submit" class="btn btn-primary btn-sm">Buscar</button>
      <% if (buscar) { %>
        <a href="/pacientes" class="btn btn-sm" style="background: var(--border);">Limpiar</a>
      <% } %>
    </form>
    <a href="/pacientes/nuevo" class="btn btn-success">+ Nuevo Paciente</a>
  </div>

  <% if (pacientes.length > 0) { %>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Teléfono</th>
            <th>Email</th>
            <th>Fecha Nac.</th>
            <th>Notas</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% pacientes.forEach(p => { %>
            <tr>
              <td><strong><%= p.nombre %></strong></td>
              <td><%= p.telefono %></td>
              <td><%= p.email || '-' %></td>
              <td><%= p.fecha_nacimiento || '-' %></td>
              <td><%= p.notas ? (p.notas.length > 40 ? p.notas.substring(0, 40) + '...' : p.notas) : '-' %></td>
              <td>
                <div class="btn-group">
                  <a href="/pacientes/editar/<%= p.id %>" class="btn btn-primary btn-sm">Editar</a>
                  <form class="confirm-delete" method="POST" action="/pacientes/eliminar/<%= p.id %>">
                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty">
      <% if (buscar) { %>
        No se encontraron pacientes con "<%= buscar %>"
      <% } else { %>
        No hay pacientes registrados todavía
      <% } %>
    </div>
  <% } %>
</div>

<%- include('footer') %>
